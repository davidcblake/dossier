# Postgres connection string (Supabase or Vercel Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/dossier"

# Google OAuth client (see docs/google-cloud-setup.md)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Anthropic API key (used from Phase 2 onward)
ANTHROPIC_API_KEY=""

# 32-byte key for AES-256-GCM token encryption, as 64 hex chars.
# Generate with: openssl rand -hex 32
TOKEN_ENC_KEY=""

# Web Push VAPID keys (used from Phase 5 onward)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Shared secret protecting /api/cron/scan (used from Phase 5 onward)
CRON_SECRET=""

# Public base URL of the deployment.
# Production: https://mydossier.vercel.app   ·   Local dev: http://localhost:3000
APP_URL="http://localhost:3000"
